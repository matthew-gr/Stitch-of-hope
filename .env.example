# ------- Supabase -------
# Find these in Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------- Admin -------
# The shared password for /admin login (choose a strong one)
ADMIN_PASSWORD=change-me-to-something-long

# Must be at least 32 characters. Used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-32+-character-string

# ------- Email (form submissions) -------
# Current destination for contact & product-request emails (via FormSubmit.co)
FORMSUBMIT_EMAIL=Dalton.hardage@yahoo.com
